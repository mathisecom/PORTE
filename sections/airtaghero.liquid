{% comment %}
  Wallet AirTag Hero Section
{% endcomment %}

<section id="wallet-hero-{{ section.id }}" class="wallet-hero">
  <div class="wallet-hero__overlay"></div>

  <div class="wallet-hero__content">
    {% if section.settings.show_badge %}
      <div class="wallet-hero__badge">
        <span class="wallet-hero__stars">{{ section.settings.badge_stars }}</span>
        <span>{{ section.settings.badge_text }}</span>
      </div>
    {% endif %}

    <h2 class="wallet-hero__title">
      {{ section.settings.title | newline_to_br }}
    </h2>

    <div class="wallet-hero__subtitle">
      {{ section.settings.subtitle | newline_to_br }}
    </div>

    {% if section.settings.button_text != blank %}
      <a href="{{ section.settings.button_link }}" class="wallet-hero__button">
        {{ section.settings.button_text }}
      </a>
    {% endif %}

    {% if section.settings.guarantee_text != blank %}
      <div class="wallet-hero__guarantee">
        <span class="wallet-hero__lock">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <rect x="5" y="10" width="14" height="10" rx="2"></rect>
            <path d="M8 10V7a4 4 0 0 1 8 0v3"></path>
          </svg>
        </span>
        <span>{{ section.settings.guarantee_text }}</span>
      </div>
    {% endif %}

    <div class="wallet-hero__features">
      {% for block in section.blocks %}
        <div class="wallet-hero__feature" {{ block.shopify_attributes }}>
          <div class="wallet-hero__icon">
            {% case block.settings.icon %}
              {% when 'pin' %}
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M12 21s7-6.1 7-12A7 7 0 0 0 5 9c0 5.9 7 12 7 12Z"></path>
                  <circle cx="12" cy="9" r="2.6"></circle>
                </svg>

              {% when 'rfid' %}
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <rect x="3" y="5" width="13" height="14" rx="2"></rect>
                  <path d="M17 8c2 1.4 3 3.2 3 5s-1 3.6-3 5"></path>
                  <path d="M18.5 5.5c2.8 2 4.5 4.6 4.5 7.5s-1.7 5.5-4.5 7.5"></path>
                  <text x="5.2" y="15.3" font-size="5" fill="currentColor" stroke="none">RFID</text>
                </svg>

              {% when 'sparkle' %}
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M12 2l2.1 6.2L20 11l-5.9 2.8L12 20l-2.1-6.2L4 11l5.9-2.8L12 2Z"></path>
                  <path d="M19 15l.9 2.4L22 18.5l-2.1 1.1L19 22l-.9-2.4L16 18.5l2.1-1.1L19 15Z"></path>
                </svg>
            {% endcase %}
          </div>

          <div class="wallet-hero__feature-title">
            {{ block.settings.title | newline_to_br }}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  #wallet-hero-{{ section.id }} {
    position: relative;
    overflow: hidden;
    width: 100%;
    min-height: {{ section.settings.mobile_height }}px;
    background-size: cover;
    background-position: {{ section.settings.image_position }};
    background-repeat: no-repeat;
    color: {{ section.settings.text_color }};
    font-family: inherit;

    {% if section.settings.background_image != blank %}
      background-image: url({{ section.settings.background_image | image_url: width: 1800 }});
    {% else %}
      background-image: linear-gradient(180deg, #222222, #111111);
    {% endif %}
  }

  #wallet-hero-{{ section.id }} .wallet-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, {{ section.settings.overlay_top | times: 0.01 }}) 0%,
      rgba(0, 0, 0, {{ section.settings.overlay_middle | times: 0.01 }}) 45%,
      rgba(0, 0, 0, {{ section.settings.overlay_bottom | times: 0.01 }}) 100%
    );
    z-index: 1;
  }

  #wallet-hero-{{ section.id }} .wallet-hero__content {
    position: relative;
    z-index: 2;
    max-width: {{ section.settings.content_width }}px;
    margin: 0 auto;
    padding: {{ section.settings.padding_top }}px {{ section.settings.side_padding }}px {{ section.settings.padding_bottom }}px;
    text-align: center;
  }

  #wallet-hero-{{ section.id }} .wallet-hero__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
    padding: 5px 13px;
    border: 1px solid {{ section.settings.badge_border_color }};
    border-radius: 999px;
    color: {{ section.settings.badge_text_color }};
    font-size: {{ section.settings.badge_size }}px;
    line-height: 1;
    background: {{ section.settings.badge_bg }};
    margin-bottom: {{ section.settings.badge_margin_bottom }}px;
  }

  #wallet-hero-{{ section.id }} .wallet-hero__stars {
    color: {{ section.settings.stars_color }};
    letter-spacing: 1px;
    font-size: {{ section.settings.stars_size }}px;
  }

  #wallet-hero-{{ section.id }} .wallet-hero__title {
    margin: 0;
    color: {{ section.settings.title_color }};
    font-size: {{ section.settings.title_size_mobile }}px;
    line-height: {{ section.settings.title_line_height }};
    font-weight: {{ section.settings.title_weight }};
    letter-spacing: {{ section.settings.title_letter_spacing }}px;
    text-transform: uppercase;
  }

  #wallet-hero-{{ section.id }} .wallet-hero__subtitle {
    max-width: {{ section.settings.subtitle_width }}px;
    margin: {{ section.settings.subtitle_margin_top }}px auto 0;
    color: {{ section.settings.subtitle_color }};
    font-size: {{ section.settings.subtitle_size_mobile }}px;
    line-height: {{ section.settings.subtitle_line_height }};
    font-weight: {{ section.settings.subtitle_weight }};
  }

  #wallet-hero-{{ section.id }} .wallet-hero__button {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: {{ section.settings.button_height }}px;
    margin: {{ section.settings.button_margin_top }}px auto 0;
    padding: 0 18px;
    border-radius: {{ section.settings.button_radius }}px;
    background: {{ section.settings.button_bg }};
    color: {{ section.settings.button_text_color }};
    border: {{ section.settings.button_border_width }}px solid {{ section.settings.button_border_color }};
    box-shadow: 0 3px 0 {{ section.settings.button_shadow_color }};
    font-size: {{ section.settings.button_text_size }}px;
    font-weight: {{ section.settings.button_weight }};
    text-decoration: none;
    text-transform: uppercase;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  #wallet-hero-{{ section.id }} .wallet-hero__button:hover {
    transform: translateY(-2px);
    opacity: 0.95;
  }

  #wallet-hero-{{ section.id }} .wallet-hero__guarantee {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
    margin-top: {{ section.settings.guarantee_margin_top }}px;
    color: {{ section.settings.guarantee_color }};
    font-size: {{ section.settings.guarantee_size }}px;
    line-height: 1;
  }

  #wallet-hero-{{ section.id }} .wallet-hero__lock {
    display: inline-flex;
    width: {{ section.settings.guarantee_icon_size }}px;
    height: {{ section.settings.guarantee_icon_size }}px;
  }

  #wallet-hero-{{ section.id }} .wallet-hero__lock svg {
    width: 100%;
    height: 100%;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  #wallet-hero-{{ section.id }} .wallet-hero__features {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ section.settings.feature_gap }}px;
    margin-top: {{ section.settings.features_margin_top }}px;
  }

  #wallet-hero-{{ section.id }} .wallet-hero__feature {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  #wallet-hero-{{ section.id }} .wallet-hero__feature::after {
    content: "";
    width: 1px;
    height: {{ section.settings.dotted_line_height }}px;
    margin-top: 8px;
    border-left: 1px dotted {{ section.settings.dotted_line_color }};
    opacity: {{ section.settings.dotted_line_opacity | times: 0.01 }};
  }

  #wallet-hero-{{ section.id }} .wallet-hero__icon {
    width: {{ section.settings.icon_circle_size }}px;
    height: {{ section.settings.icon_circle_size }}px;
    border-radius: 50%;
    border: 1px dotted {{ section.settings.icon_border_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ section.settings.icon_color }};
    background: {{ section.settings.icon_bg }};
  }

  #wallet-hero-{{ section.id }} .wallet-hero__icon svg {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  #wallet-hero-{{ section.id }} .wallet-hero__feature-title {
    margin-top: {{ section.settings.feature_text_margin_top }}px;
    color: {{ section.settings.feature_text_color }};
    font-size: {{ section.settings.feature_text_size }}px;
    line-height: {{ section.settings.feature_line_height }};
    font-weight: {{ section.settings.feature_weight }};
  }

  @media screen and (min-width: 750px) {
    #wallet-hero-{{ section.id }} {
      min-height: {{ section.settings.desktop_height }}px;
    }

    #wallet-hero-{{ section.id }} .wallet-hero__title {
      font-size: {{ section.settings.title_size_desktop }}px;
    }

    #wallet-hero-{{ section.id }} .wallet-hero__subtitle {
      font-size: {{ section.settings.subtitle_size_desktop }}px;
    }
  }
</style>

{% schema %}
{
  "name": "Wallet AirTag Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Image de fond"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Position de l'image",
      "default": "center center",
      "options": [
        {
          "value": "center center",
          "label": "Centre"
        },
        {
          "value": "top center",
          "label": "Haut"
        },
        {
          "value": "bottom center",
          "label": "Bas"
        },
        {
          "value": "center left",
          "label": "Gauche"
        },
        {
          "value": "center right",
          "label": "Droite"
        }
      ]
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "Hauteur mobile",
      "min": 500,
      "max": 1000,
      "step": 10,
      "default": 860
    },
    {
      "type": "range",
      "id": "desktop_height",
      "label": "Hauteur desktop",
      "min": 500,
      "max": 1100,
      "step": 10,
      "default": 900
    },
    {
      "type": "range",
      "id": "content_width",
      "label": "Largeur du contenu",
      "min": 300,
      "max": 700,
      "step": 10,
      "default": 430
    },
    {
      "type": "range",
      "id": "side_padding",
      "label": "Marge côtés",
      "min": 10,
      "max": 50,
      "step": 1,
      "default": 34
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Marge haut",
      "min": 0,
      "max": 120,
      "step": 2,
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Marge bas",
      "min": 0,
      "max": 120,
      "step": 2,
      "default": 20
    },
    {
      "type": "range",
      "id": "overlay_top",
      "label": "Opacité sombre haut",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 82
    },
    {
      "type": "range",
      "id": "overlay_middle",
      "label": "Opacité sombre milieu",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 36
    },
    {
      "type": "range",
      "id": "overlay_bottom",
      "label": "Opacité sombre bas",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "show_badge",
      "label": "Afficher le badge avis",
      "default": true
    },
    {
      "type": "text",
      "id": "badge_stars",
      "label": "Étoiles",
      "default": "★★★★★"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Texte badge",
      "default": "Over 1,800+ 5 Star Reviews"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Titre",
      "default": "SLEEK. SECURE.\nTRACKABLE."
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Sous-titre",
      "default": "With built-in tracking and RFID protection, your wallet stays secure and always within reach—wherever life takes you."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Texte bouton",
      "default": "CLAIM 50% OFF | LIMITED TIME OFFER"
    },
    {
      "type": "url",
