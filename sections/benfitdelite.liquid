{% comment %}
  Bande défilante avantages - Shopify Section
{% endcomment %}

<section id="marquee-benefits-{{ section.id }}" class="marquee-benefits">
  <div class="marquee-benefits__wrapper">
    <div class="marquee-benefits__track">
      {% for i in (1..section.settings.repeat_count) %}
        {% for block in section.blocks %}
          <div class="marquee-benefits__item" {{ block.shopify_attributes }}>
            {% if block.settings.icon_image != blank %}
              <img
                class="marquee-benefits__icon-image"
                src="{{ block.settings.icon_image | image_url: width: 80 }}"
                alt=""
                loading="lazy"
              >
            {% else %}
              <span class="marquee-benefits__icon">
                {% case block.settings.icon %}
                  {% when 'card' %}
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                      <rect x="3" y="5" width="18" height="14" rx="2"></rect>
                      <path d="M3 10h18"></path>
                      <path d="M7 15h4"></path>
                    </svg>

                  {% when 'rfid' %}
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                      <rect x="3" y="5" width="12" height="14" rx="2"></rect>
                      <path d="M17 8c1.5 1.3 2.2 2.8 2.2 5s-.7 3.7-2.2 5"></path>
                      <path d="M19 5.5c2.2 2 3.4 4.5 3.4 7.5s-1.2 5.5-3.4 7.5"></path>
                      <text x="5" y="15.2" font-size="4.7" fill="currentColor" stroke="none">RFID</text>
                    </svg>

                  {% when 'carbon' %}
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M4 4h6v6H4z"></path>
                      <path d="M14 4h6v6h-6z"></path>
                      <path d="M4 14h6v6H4z"></path>
                      <path d="M14 14h6v6h-6z"></path>
                      <path d="M10 10h4v4h-4z"></path>
                    </svg>

                  {% when 'shield' %}
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M12 3l8 3v6c0 5-3.3 8.5-8 9-4.7-.5-8-4-8-9V6l8-3Z"></path>
                      <path d="M9 12l2 2 4-5"></path>
                    </svg>

                  {% when 'lock' %}
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                      <rect x="5" y="10" width="14" height="10" rx="2"></rect>
                      <path d="M8 10V7a4 4 0 0 1 8 0v3"></path>
                    </svg>

                  {% when 'truck' %}
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M3 7h11v10H3z"></path>
                      <path d="M14 10h4l3 3v4h-7z"></path>
                      <circle cx="7" cy="18" r="2"></circle>
                      <circle cx="17" cy="18" r="2"></circle>
                    </svg>

                  {% when 'star' %}
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M12 3l2.7 5.5 6.1.9-4.4 4.3 1 6.1L12 17l-5.4 2.8 1-6.1-4.4-4.3 6.1-.9L12 3Z"></path>
                    </svg>

                  {% when 'check' %}
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                      <circle cx="12" cy="12" r="9"></circle>
                      <path d="M8 12.5l2.5 2.5L16 9"></path>
                    </svg>
                {% endcase %}
              </span>
            {% endif %}

            <span class="marquee-benefits__text">
              {{ block.settings.text }}
            </span>
          </div>
        {% endfor %}
      {% endfor %}
    </div>
  </div>
</section>

<style>
  #marquee-benefits-{{ section.id }} {
    width: 100%;
    overflow: hidden;
    background: {{ section.settings.background_color }};
    border-top: {{ section.settings.border_top_width }}px solid {{ section.settings.border_color }};
    border-bottom: {{ section.settings.border_bottom_width }}px solid {{ section.settings.border_color }};
  }

  #marquee-benefits-{{ section.id }} .marquee-benefits__wrapper {
    width: 100%;
    overflow: hidden;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  #marquee-benefits-{{ section.id }} .marquee-benefits__track {
    display: flex;
    align-items: center;
    width: max-content;
    gap: {{ section.settings.item_gap }}px;
    animation-name: marquee-scroll-{{ section.id }};
    animation-duration: {{ section.settings.speed }}s;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
    {% if section.settings.direction == 'right' %}
      animation-direction: reverse;
    {% endif %}
  }

  {% if section.settings.pause_on_hover %}
    #marquee-benefits-{{ section.id }}:hover .marquee-benefits__track {
      animation-play-state: paused;
    }
  {% endif %}

  #marquee-benefits-{{ section.id }} .marquee-benefits__item {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: {{ section.settings.icon_text_gap }}px;
    white-space: nowrap;
    color: {{ section.settings.text_color }};
    font-size: {{ section.settings.text_size_mobile }}px;
    font-weight: {{ section.settings.text_weight }};
    line-height: {{ section.settings.text_line_height }}%;
    letter-spacing: {{ section.settings.letter_spacing }}px;
    text-transform: {{ section.settings.text_transform }};
  }

  #marquee-benefits-{{ section.id }} .marquee-benefits__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: {{ section.settings.icon_box_size }}px;
    height: {{ section.settings.icon_box_size }}px;
    color: {{ section.settings.icon_color }};
    flex: 0 0 auto;
  }

  #marquee-benefits-{{ section.id }} .marquee-benefits__icon svg {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    fill: none;
    stroke: currentColor;
    stroke-width: {{ section.settings.icon_stroke_width }};
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  #marquee-benefits-{{ section.id }} .marquee-benefits__icon svg text {
    font-family: Arial, sans-serif;
    font-weight: 700;
  }

  #marquee-benefits-{{ section.id }} .marquee-benefits__icon-image {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    object-fit: contain;
    flex: 0 0 auto;
  }

  #marquee-benefits-{{ section.id }} .marquee-benefits__text {
    display: inline-block;
  }

  @keyframes marquee-scroll-{{ section.id }} {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  @media screen and (min-width: 750px) {
    #marquee-benefits-{{ section.id }} .marquee-benefits__item {
      font-size: {{ section.settings.text_size_desktop }}px;
    }
  }
</style>

{% schema %}
{
  "name": "Bande défilante avantages",
  "settings": [
    {
      "type": "header",
      "content": "Couleurs"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Couleur de fond",
      "default": "#ead39b"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Couleur du texte",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Couleur des icônes",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Couleur des bordures",
      "default": "#111111"
    },
    {
      "type": "header",
      "content": "Dimensions"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Marge intérieure haut",
      "min": 0,
      "max": 40,
      "step": 1,
      "default": 7
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Marge intérieure bas",
      "min": 0,
      "max": 40,
      "step": 1,
      "default": 7
    },
    {
      "type": "range",
      "id": "item_gap",
      "label": "Espace entre les éléments",
      "min": 10,
      "max": 120,
      "step": 2,
      "default": 46
    },
    {
      "type": "range",
      "id": "icon_text_gap",
      "label": "Espace icône / texte",
      "min": 2,
      "max": 30,
      "step": 1,
      "default": 8
    },
    {
      "type": "range",
      "id": "border_top_width",
      "label": "Épaisseur bordure haute",
      "min": 0,
      "max": 8,
      "step": 1,
      "default": 1
    },
    {
      "type": "range",
      "id": "border_bottom_width",
      "label": "Épaisseur bordure basse",
      "min": 0,
      "max": 8,
      "step": 1,
      "default": 1
    },
    {
      "type": "header",
      "content": "Texte"
    },
    {
      "type": "range",
      "id": "text_size_mobile",
      "label": "Taille texte mobile",
      "min": 8,
      "max": 28,
      "step": 1,
      "default": 13
    },
    {
      "type": "range",
      "id": "text_size_desktop",
      "label": "Taille texte desktop",
      "min": 8,
      "max": 34,
      "step": 1,
      "default": 14
    },
    {
      "type": "range",
      "id": "text_weight",
      "label": "Graisse du texte",
      "min": 300,
      "max": 900,
      "step": 100,
      "default": 700
    },
    {
      "type": "range",
      "id": "text_line_height",
      "label": "Interligne du texte",
      "min": 80,
      "max": 200,
      "step": 5,
      "default": 100
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "label": "Espacement des lettres",
      "min": -2,
      "max": 5,
      "step": 1,
      "default": 0
    },
    {
      "type": "select",
      "id": "text_transform",
      "label": "Transformation du texte",
      "default": "none",
      "options": [
        {
          "value": "none",
          "label": "Normal"
        },
        {
          "value": "uppercase",
          "label": "Majuscules"
        },
        {
          "value": "lowercase",
          "label": "Minuscules"
        },
        {
          "value": "capitalize",
          "label": "Première lettre en majuscule"
        }
      ]
    },
    {
      "type": "header",
      "content": "Icônes"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Taille des icônes",
      "min": 10,
      "max": 42,
      "step": 1,
      "default": 18
    },
    {
      "type": "range",
      "id": "icon_box_size",
      "label": "Taille zone icône",
      "min": 10,
      "max": 50,
      "step": 1,
      "default": 22
    },
    {
      "type": "range",
      "id": "icon_stroke_width",
      "label": "Épaisseur trait icône",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2
    },
    {
      "type": "header",
      "content": "Défilement"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Vitesse du défilement",
      "min": 5,
      "max": 80,
      "step": 1,
      "default": 22
    },
    {
      "type": "select",
      "id": "direction",
      "label": "Sens du défilement",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "Vers la gauche"
        },
        {
          "value": "right",
          "label": "Vers la droite"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause au survol",
      "default": true
    },
    {
      "type": "range",
      "id": "repeat_count",
      "label": "Nombre de répétitions",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 8
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Avantage",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Texte",
          "default": "Quick Card Access"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icône",
          "default": "card",
          "options": [
            {
              "value": "card",
              "label": "Carte"
            },
            {
              "value": "rfid",
              "label": "RFID"
            },
            {
              "value": "carbon",
              "label": "Carbone"
            },
            {
              "value": "shield",
              "label": "Bouclier"
            },
            {
              "value": "lock",
              "label": "Cadenas"
            },
            {
              "value": "truck",
              "label": "Livraison"
            },
            {
              "value": "star",
              "label": "Étoile"
            },
            {
              "value": "check",
              "label": "Validation"
            }
          ]
        },
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icône personnalisée",
          "info": "Si une image est ajoutée ici, elle remplacera l’icône sélectionnée."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bande défilante avantages",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "text": "Quick Card Access",
            "icon": "card"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "text": "RFID Blocking Security",
            "icon": "rfid"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "text": "Carbon Fiber",
            "icon": "carbon"
          }
        }
      ]
    }
  ]
}
{% endschema %}